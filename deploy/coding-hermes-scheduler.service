[Unit]
Description=Coding Hermes Fleet Scheduler
After=network.target

[Service]
Type=simple
User=kara
ExecStart=/home/kara/coding-herms-scheduler/bin/schedulerd -db /home/kara/.hermes/scheduler.db -listen 127.0.0.1:9090
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=HOME=/home/kara

[Install]
WantedBy=default.target
